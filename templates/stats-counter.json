{
  "id": "stats-counter",
  "name": "Animated Stats Counter",
  "description": "Metrics grid with spring-animated number counters and configurable suffixes",
  "composition": "StatsCounter",
  "defaults": {
    "fps": 30,
    "width": 1920,
    "height": 1080,
    "durationBehavior": "fixed",
    "background": {
      "type": "gradient",
      "from": "#0a0a1a",
      "to": "#1a1a3e"
    },
    "title": "Results That Speak",
    "stats": [
      { "value": 250, "label": "Revenue Growth", "suffix": "%" },
      { "value": 50, "label": "Active Users", "suffix": "K" },
      { "value": 99, "label": "Uptime", "suffix": "%" },
      { "value": 4, "label": "Time Saved", "suffix": "x" }
    ],
    "textColor": "#ffffff",
    "accentColor": "#00d4ff",
    "fontFamily": "Inter",
    "branding": {
      "logo": null,
      "watermark": null
    }
  },
  "platforms": {
    "youtube": { "width": 1920, "height": 1080 },
    "tiktok": { "width": 1080, "height": 1920 },
    "reels": { "width": 1080, "height": 1920 },
    "square": { "width": 1080, "height": 1080 }
  }
}
