# HeyGen — Digital twin avatar videos
# Get your API key at https://app.heygen.com/settings?nav=API
HEYGEN_API_KEY=your_heygen_api_key

# Higgsfield — AI video generation (requires Studio plan $199/mo)
# Get credentials at https://higgsfield.ai/settings/api
HF_API_KEY=your_higgsfield_key_id
HF_API_SECRET=your_higgsfield_key_secret

# Google Gemini — Image generation (banana-claude)
# Get your key at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key

# Remotion rendering
REMOTION_CONCURRENCY=2
REMOTION_QUALITY=80

# FFmpeg
FFMPEG_THREADS=4

# TTS defaults
DEFAULT_VOICE=es-MX-JorgeNeural
DEFAULT_LANGUAGE=es

# Output
OUTPUT_DIR=./output
